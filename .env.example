# ================================================================
# IMSP Platform - Environment Configuration
# ================================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# ================================================================

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=postgres
KEYCLOAK_REALM=imsp
KEYCLOAK_CLIENT_ID=imsp-api

# --- Gateway ---
ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:8080

# --- Core API ---
APP_API_KEY=
JWT_SECRET_KEY=
LOG_FORMAT=json

# --- Activepieces ---
AP_ENCRYPTION_KEY=__GENERATE_WITH_openssl_rand_hex_16__
AP_JWT_SECRET=__GENERATE_WITH_openssl_rand_hex_32__
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=postgres
AP_FRONTEND_URL=http://localhost:8081

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=imsp

# --- Redis ---
REDIS_URL=redis://localhost:6379/1

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=imsp_vectors

# --- Ollama (Embedding/LLM) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Observability ---
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# --- Gateway (extended) ---
GATEWAY_WS_SECRET_KEY=__GENERATE_WITH_openssl_rand_hex_32__
GATEWAY_RATE_LIMIT_PER_MINUTE=60
GATEWAY_WS_REQUIRE_AUTH=true

# --- RAG / Reranker ---
RERANKER_API_KEY=
RERANKER_BACKEND=score_boost

# --- Agent ---
MEMORY_BACKEND=buffer
LLM_PROVIDER=ollama
LLM_MODEL=llama3
