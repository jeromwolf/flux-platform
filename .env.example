# ================================================================
# IMSP Platform - Environment Configuration
# ================================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# ================================================================

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=postgres
KEYCLOAK_REALM=imsp
KEYCLOAK_CLIENT_ID=imsp-api

# --- Gateway ---
ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:8080

# --- Core API ---
APP_API_KEY=
JWT_SECRET_KEY=
LOG_FORMAT=json

# --- Activepieces ---
AP_ENCRYPTION_KEY=__GENERATE_WITH_openssl_rand_hex_16__
AP_JWT_SECRET=__GENERATE_WITH_openssl_rand_hex_32__
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=postgres
AP_FRONTEND_URL=http://localhost:8081

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
