# Local development only — DO NOT use in production
# Copy to secret.yaml and fill in values: cp secret-template.yaml.example secret.yaml
#
# Production: use external-secret.yaml with External Secrets Operator instead.
# See: infra/k8s/base/external-secret.yaml and infra/k8s/base/secret-store.yaml
apiVersion: v1
kind: Secret
metadata:
  name: imsp-secrets
  namespace: imsp
type: Opaque
stringData:
  NEO4J_USER: "neo4j"
  NEO4J_PASSWORD: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"
  REDIS_PASSWORD: "CHANGE_ME"
  JWT_SECRET_KEY: "CHANGE_ME"
  KEYCLOAK_ADMIN: "admin"
  KEYCLOAK_ADMIN_PASSWORD: "CHANGE_ME"
  KC_DB_USERNAME: "postgres"
  KC_DB_PASSWORD: "CHANGE_ME"
  AP_POSTGRES_USERNAME: "postgres"
  AP_POSTGRES_PASSWORD: "CHANGE_ME"
  APP_API_KEY: "CHANGE_ME"
