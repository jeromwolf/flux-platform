{
  "dashboard": {
    "id": null,
    "uid": "imsp-logs-overview",
    "title": "IMSP Logs Overview",
    "tags": ["imsp", "logs", "loki"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "schemaVersion": 30,
    "version": 1,
    "templating": {
      "list": [
        {
          "name": "service",
          "label": "Service",
          "type": "custom",
          "current": { "text": "All", "value": "" },
          "options": [
            { "text": "All", "value": "", "selected": true },
            { "text": "kg-api", "value": "imsp-kg-api", "selected": false },
            { "text": "gateway", "value": "imsp-gateway", "selected": false },
            { "text": "keycloak", "value": "imsp-keycloak", "selected": false },
            { "text": "neo4j", "value": "imsp-neo4j", "selected": false }
          ],
          "hide": 0,
          "skipUrlSync": false
        },
        {
          "name": "level",
          "label": "Level",
          "type": "custom",
          "current": { "text": "All", "value": "" },
          "options": [
            { "text": "All", "value": "", "selected": true },
            { "text": "ERROR", "value": "error", "selected": false },
            { "text": "WARNING", "value": "warning", "selected": false },
            { "text": "INFO", "value": "info", "selected": false },
            { "text": "DEBUG", "value": "debug", "selected": false }
          ],
          "hide": 0,
          "skipUrlSync": false
        },
        {
          "name": "search",
          "label": "Search",
          "type": "textbox",
          "current": { "text": "", "value": "" },
          "hide": 0,
          "skipUrlSync": false
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Log Volume",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "loki", "uid": "loki" },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 50,
              "stacking": { "mode": "normal" }
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "sum by (level) (count_over_time({job=\"imsp\"} |~ \"$search\" [$__interval]))",
            "legendFormat": "{{level}}",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 2,
        "title": "Error Rate (5m)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "sum(count_over_time({job=\"imsp\"} |= \"ERROR\" [5m]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            },
            "mappings": []
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Warning Rate (5m)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "sum(count_over_time({job=\"imsp\"} |= \"WARNING\" [5m]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 20 },
                { "color": "orange", "value": 100 }
              ]
            },
            "mappings": []
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Top Error Messages",
        "type": "table",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 6 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "topk(10, sum by (message) (count_over_time({job=\"imsp\"} |= \"ERROR\" | json | line_format \"{{.message}}\" [1h])))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        },
        "options": {}
      },
      {
        "id": 5,
        "title": "Application Logs",
        "type": "logs",
        "gridPos": { "h": 16, "w": 24, "x": 0, "y": 10 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "{job=\"imsp\", container_name=~\"${service:pipe}.*\"} |~ \"$search\" | json | level=~\"${level:pipe}.*\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": true,
          "enableLogDetails": true,
          "sortOrder": "Descending",
          "dedupStrategy": "none"
        }
      },
      {
        "id": 6,
        "title": "Auth Failures",
        "type": "logs",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "{job=\"imsp\"} |~ \"(401|403|Unauthorized|Forbidden|authentication|JWT|token expired)\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 7,
        "title": "Slow Queries (>2s)",
        "type": "logs",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
        "datasource": { "type": "loki", "uid": "loki" },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "loki" },
            "expr": "{job=\"imsp\"} |~ \"(duration|elapsed|took)\" | json | duration > 2s",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        }
      }
    ]
  }
}
