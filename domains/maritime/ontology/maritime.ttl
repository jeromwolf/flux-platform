    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:Voyage ;
    rdfs:label "ON_VOYAGE" ;
    rdfs:comment "Vessel is performing a voyage" .

maritime:FROM_PORT a owl:ObjectProperty ;
    rdfs:domain maritime:Voyage ;
    rdfs:range maritime:Port ;
    rdfs:label "FROM_PORT" ;
    rdfs:comment "Voyage originates from a port" .

maritime:TO_PORT a owl:ObjectProperty ;
    rdfs:domain maritime:Voyage ;
    rdfs:range maritime:Port ;
    rdfs:label "TO_PORT" ;
    rdfs:comment "Voyage is destined for a port" .

maritime:CONSISTS_OF a owl:ObjectProperty ;
    rdfs:domain maritime:Voyage ;
    rdfs:range maritime:TrackSegment ;
    rdfs:label "CONSISTS_OF" ;
    rdfs:comment "Voyage is composed of track segments" .

maritime:CARRIES a owl:ObjectProperty ;
    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:Cargo ;
    rdfs:label "CARRIES" ;
    rdfs:comment "Vessel is carrying cargo" .

maritime:PERFORMS a owl:ObjectProperty ;
    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:Activity ;
    rdfs:label "PERFORMS" ;
