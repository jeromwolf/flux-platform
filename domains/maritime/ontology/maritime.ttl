# 4.6 AgentEntity 그룹 (8개)
# ---------------------------------------------------------------------------

maritime:Organization a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity ;
    rdfs:label "Organization" ;
    rdfs:comment "Legal entity (company, government body, institute)" .

maritime:GovernmentAgency a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Organization ;
    rdfs:label "GovernmentAgency" ;
    rdfs:comment "Government ministry or agency" .

maritime:ShippingCompany a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Organization ;
    rdfs:label "ShippingCompany" ;
    rdfs:comment "Commercial shipping or logistics company" .

maritime:ResearchInstitute a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Organization ;
    rdfs:label "ResearchInstitute" ;
    rdfs:comment "Research institute or university" .

maritime:ClassificationSociety a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Organization ;
    rdfs:label "ClassificationSociety" ;
    rdfs:comment "Ship classification society (KR, DNV, LR, etc.)" .

maritime:Person a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity ;
    rdfs:label "Person" ;
    rdfs:comment "An individual person" .

maritime:CrewMember a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Person ;
    rdfs:label "CrewMember" ;
    rdfs:comment "Person serving as crew aboard a vessel" .

maritime:Inspector a owl:Class ;
    rdfs:subClassOf maritime:AgentEntity , maritime:Person ;
    rdfs:label "Inspector" ;
    rdfs:comment "Person conducting inspections" .

# ---------------------------------------------------------------------------
# 4.7 PlatformResource 그룹 (8개)
# ---------------------------------------------------------------------------

maritime:Workflow a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "Workflow" ;
    rdfs:comment "Automated data processing or analysis workflow definition" .

maritime:WorkflowNode a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "WorkflowNode" ;
    rdfs:comment "Individual processing step within a workflow" .

maritime:WorkflowExecution a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "WorkflowExecution" ;
    rdfs:comment "A single execution instance of a workflow" .

maritime:AIModel a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "AIModel" ;
    rdfs:comment "Machine learning or AI model used for inference" .

maritime:DataPipeline a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "DataPipeline" ;
    rdfs:comment "Scheduled data ingestion or transformation pipeline" .

maritime:AIAgent a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "AIAgent" ;
    rdfs:comment "Autonomous AI agent that orchestrates tasks via MCP" .

maritime:MCPTool a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "MCPTool" ;
    rdfs:comment "Tool exposed via Model Context Protocol for agent use" .

maritime:MCPResource a owl:Class ;
    rdfs:subClassOf maritime:PlatformResource ;
    rdfs:label "MCPResource" ;
    rdfs:comment "Resource exposed via MCP (schema, data view, etc.)" .

