# ---------------------------------------------------------------------------
# 4.10 KRISOEntity 그룹 (23개)
# ---------------------------------------------------------------------------

maritime:Experiment a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "Experiment" ;
    rdfs:comment "KRISO experimental test campaign" .

maritime:TestFacility a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "TestFacility" ;
    rdfs:comment "Physical test facility at KRISO" .

maritime:TowingTank a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "TowingTank" ;
    rdfs:comment "Towing tank facility for resistance/propulsion tests" .

maritime:OceanEngineeringBasin a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "OceanEngineeringBasin" ;
    rdfs:comment "Ocean engineering basin for seakeeping tests" .

maritime:IceTank a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "IceTank" ;
    rdfs:comment "Ice model basin for ice-going vessel tests" .

maritime:DeepOceanBasin a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "DeepOceanBasin" ;
    rdfs:comment "Deep ocean engineering basin" .

maritime:WaveEnergyTestSite a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "WaveEnergyTestSite" ;
    rdfs:comment "Open-sea wave energy converter test site" .

maritime:HyperbaricChamber a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "HyperbaricChamber" ;
    rdfs:comment "Hyperbaric pressure testing chamber" .

maritime:CavitationTunnel a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "CavitationTunnel" ;
    rdfs:comment "Cavitation tunnel for propeller/hull cavitation tests" .

maritime:LargeCavitationTunnel a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:CavitationTunnel ;
    rdfs:label "LargeCavitationTunnel" ;
    rdfs:comment "Large cavitation tunnel (대형 캐비테이션터널)" .

maritime:MediumCavitationTunnel a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:CavitationTunnel ;
    rdfs:label "MediumCavitationTunnel" ;
    rdfs:comment "Medium cavitation tunnel (중형 캐비테이션터널)" .

maritime:HighSpeedCavitationTunnel a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:CavitationTunnel ;
    rdfs:label "HighSpeedCavitationTunnel" ;
    rdfs:comment "High-speed cavitation tunnel (고속 캐비테이션터널)" .

maritime:BridgeSimulator a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:TestFacility ;
    rdfs:label "BridgeSimulator" ;
    rdfs:comment "Full Mission Bridge Simulator for navigation training and research (선박운항시뮬레이터)" .

maritime:ExperimentalDataset a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "ExperimentalDataset" ;
    rdfs:comment "Dataset produced by a KRISO experiment" .

maritime:TestCondition a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "TestCondition" ;
    rdfs:comment "Environmental/operational conditions during a test" .

maritime:ModelShip a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "ModelShip" ;
    rdfs:comment "Scale model ship used in a KRISO experiment" .

maritime:Measurement a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity ;
    rdfs:label "Measurement" ;
    rdfs:comment "A single measurement record from a test" .

maritime:Resistance a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "Resistance" ;
    rdfs:comment "Resistance measurement (drag force)" .

maritime:Propulsion a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "Propulsion" ;
    rdfs:comment "Propulsion performance measurement" .

maritime:Maneuvering a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "Maneuvering" ;
    rdfs:comment "Maneuvering test measurement" .

maritime:Seakeeping a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "Seakeeping" ;
    rdfs:comment "Seakeeping performance measurement" .

maritime:IcePerformance a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "IcePerformance" ;
    rdfs:comment "Ice resistance/performance measurement" .

maritime:StructuralResponse a owl:Class ;
    rdfs:subClassOf maritime:KRISOEntity , maritime:Measurement ;
    rdfs:label "StructuralResponse" ;
    rdfs:comment "Structural load/response measurement" .

# ---------------------------------------------------------------------------
# 4.11 RBACEntity 그룹 (4개)
# ---------------------------------------------------------------------------

maritime:User a owl:Class ;
    rdfs:subClassOf maritime:RBACEntity ;
    rdfs:label "User" ;
    rdfs:comment "Platform user account" .

maritime:Role a owl:Class ;
    rdfs:subClassOf maritime:RBACEntity ;
    rdfs:label "Role" ;
    rdfs:comment "Access control role (admin, researcher, developer, public)" .

maritime:DataClass a owl:Class ;
    rdfs:subClassOf maritime:RBACEntity ;
    rdfs:label "DataClass" ;
    rdfs:comment "Data classification level for access control" .

maritime:Permission a owl:Class ;
    rdfs:subClassOf maritime:RBACEntity ;
    rdfs:label "Permission" ;
    rdfs:comment "Specific access permission on a resource" .


# ===========================================================================
# 5. 객체 속성 (Object Properties) - 83개 관계
# ===========================================================================

# ---------------------------------------------------------------------------
# 5.1 물리적 관계 (Physical Relations)
# ---------------------------------------------------------------------------

maritime:LOCATED_AT a owl:ObjectProperty ;
    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:SeaArea ;
    rdfs:label "LOCATED_AT" ;
    rdfs:comment "Current or last-known location of a vessel within a sea area" .

maritime:DOCKED_AT a owl:ObjectProperty ;
    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:Berth ;
    rdfs:label "DOCKED_AT" ;
    rdfs:comment "Vessel is currently docked at a specific berth" .

maritime:ANCHORED_AT a owl:ObjectProperty ;
    rdfs:domain maritime:Vessel ;
    rdfs:range maritime:Anchorage ;
    rdfs:label "ANCHORED_AT" ;
    rdfs:comment "Vessel is anchored at a designated anchorage" .

maritime:HAS_FACILITY a owl:ObjectProperty ;
    rdfs:domain maritime:Port ;
    rdfs:range maritime:PortFacility ;
    rdfs:label "HAS_FACILITY" ;
    rdfs:comment "Port contains or operates a facility" .

maritime:CONNECTED_VIA a owl:ObjectProperty ;
    rdfs:domain maritime:Port ;
    rdfs:range maritime:Waterway ;
    rdfs:label "CONNECTED_VIA" ;
    rdfs:comment "Port is accessible via a waterway" .

maritime:CONNECTS a owl:ObjectProperty ;
    rdfs:domain maritime:Waterway ;
    rdfs:range maritime:SeaArea ;
    rdfs:label "CONNECTS" ;
    rdfs:comment "Waterway connects two sea areas" .

# ---------------------------------------------------------------------------
# 5.2 운항 관계 (Operational Relations)
# ---------------------------------------------------------------------------

