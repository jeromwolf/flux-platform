# ===========================================================================
# 해사 도메인 온톨로지 (Maritime Domain Ontology)
# KRISO 대화형 해사서비스 플랫폼 - Neosemantics (n10s) 통합용
# ===========================================================================
# 파일: kg/ontology/maritime.ttl
# 형식: OWL 2 / Turtle
# 인코딩: UTF-8
# 버전: 1.0.0
# 생성일: 2026-02-21
# ===========================================================================

# ---------------------------------------------------------------------------
# 1. 접두사 선언 (Prefix Declarations)
# ---------------------------------------------------------------------------

@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:       <http://purl.org/dc/elements/1.1/> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix geo:      <http://www.opengis.net/ont/geosparql#> .
@prefix maritime: <https://kg.kriso.re.kr/maritime#> .
@prefix s100:     <https://registry.iho.int/s100#> .


# ---------------------------------------------------------------------------
# 2. 온톨로지 헤더 (Ontology Header)
# ---------------------------------------------------------------------------

maritime: a owl:Ontology ;
    dc:title "해사 도메인 온톨로지 (Maritime Domain Ontology)" ;
    dc:description "KRISO 대화형 해사서비스 플랫폼을 위한 해사 도메인 지식그래프 온톨로지. IHO S-100 표준과 호환." ;
    dc:creator "인사이트마이닝 (InsightMining)" ;
    dcterms:created "2026-02-21"^^xsd:date ;
    owl:versionInfo "1.0.0" .


# ===========================================================================
# 3. 상위 클래스 계층 (Superclass Hierarchy) - 11개 그룹
# ===========================================================================

maritime:PhysicalEntity a owl:Class ;
    rdfs:label "PhysicalEntity" ;
    rdfs:comment "물리적 개체 (선박, 항구, 화물, 센서)" .

maritime:SpatialEntity a owl:Class ;
    rdfs:label "SpatialEntity" ;
    rdfs:comment "공간 개체 (해역, EEZ, 지점)" .

maritime:TemporalEntity a owl:Class ;
    rdfs:label "TemporalEntity" ;
    rdfs:comment "시간적 이벤트 (항해, 사고, 활동)" .

maritime:InformationEntity a owl:Class ;
    rdfs:label "InformationEntity" ;
    rdfs:comment "정보 개체 (규정, 문서, 서비스)" .

maritime:ObservationEntity a owl:Class ;
    rdfs:label "ObservationEntity" ;
    rdfs:comment "관측 데이터" .

maritime:AgentEntity a owl:Class ;
    rdfs:label "AgentEntity" ;
    rdfs:comment "행위 주체 (조직, 사람)" .

maritime:PlatformResource a owl:Class ;
    rdfs:label "PlatformResource" ;
    rdfs:comment "플랫폼 자원 (워크플로우, AI 모델)" .

maritime:MultimodalData a owl:Class ;
    rdfs:label "MultimodalData" ;
    rdfs:comment "멀티모달 데이터 (AIS, 위성, 레이더)" .

maritime:MultimodalRepresentation a owl:Class ;
    rdfs:label "MultimodalRepresentation" ;
    rdfs:comment "임베딩 벡터" .

maritime:KRISOEntity a owl:Class ;
    rdfs:label "KRISOEntity" ;
    rdfs:comment "KRISO 시험 관련 개체" .

maritime:RBACEntity a owl:Class ;
    rdfs:label "RBACEntity" ;
    rdfs:comment "접근 제어 개체" .


# ===========================================================================
# 4. 엔티티 클래스 (Entity Classes) - 127개
# ===========================================================================

# ---------------------------------------------------------------------------
# 4.1 PhysicalEntity 그룹 (27개)
# ---------------------------------------------------------------------------

maritime:Vessel a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Vessel" ;
    rdfs:comment "Any watercraft or ship operating at sea" .

maritime:CargoShip a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "CargoShip" ;
    rdfs:comment "Vessel designed for transporting goods" .

maritime:Tanker a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "Tanker" ;
    rdfs:comment "Vessel designed for transporting liquid cargo (oil, chemicals, LNG)" .

maritime:FishingVessel a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "FishingVessel" ;
    rdfs:comment "Vessel used for commercial or artisanal fishing" .

maritime:PassengerShip a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "PassengerShip" ;
    rdfs:comment "Vessel carrying passengers (ferry, cruise ship)" .

maritime:NavalVessel a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "NavalVessel" ;
    rdfs:comment "Military or coast-guard vessel" .

maritime:AutonomousVessel a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Vessel ;
    rdfs:label "AutonomousVessel" ;
    rdfs:comment "Unmanned or remotely operated vessel (MASS)" .

maritime:Port a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Port" ;
    rdfs:comment "Harbour facility where vessels dock for loading/unloading" .

maritime:TradePort a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Port ;
    rdfs:label "TradePort" ;
    rdfs:comment "Port primarily handling commercial cargo" .

maritime:CoastalPort a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Port ;
    rdfs:label "CoastalPort" ;
    rdfs:comment "Smaller port serving coastal traffic" .

maritime:FishingPort a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Port ;
    rdfs:label "FishingPort" ;
    rdfs:comment "Port primarily serving fishing vessels" .

maritime:PortFacility a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "PortFacility" ;
    rdfs:comment "Infrastructure within a port (crane, storage, etc.)" .

maritime:Berth a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Berth" ;
    rdfs:comment "Designated mooring position within a port" .

maritime:Anchorage a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Anchorage" ;
    rdfs:comment "Designated area where vessels anchor outside a port" .

maritime:Terminal a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Terminal" ;
    rdfs:comment "Specialised cargo-handling area within a port" .

maritime:Waterway a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Waterway" ;
    rdfs:comment "Navigable body of water (strait, canal, river)" .

maritime:TSS a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "TSS" ;
    rdfs:comment "Traffic Separation Scheme defined by IMO" .

maritime:Channel a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Channel" ;
    rdfs:comment "Marked navigational channel within a waterway" .

maritime:Cargo a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Cargo" ;
    rdfs:comment "Goods transported by a vessel" .

maritime:DangerousGoods a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Cargo ;
    rdfs:label "DangerousGoods" ;
    rdfs:comment "Cargo classified as hazardous (IMDG Code)" .

maritime:BulkCargo a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Cargo ;
    rdfs:label "BulkCargo" ;
    rdfs:comment "Unpackaged bulk commodities (grain, coal, ore)" .

maritime:ContainerCargo a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Cargo ;
    rdfs:label "ContainerCargo" ;
    rdfs:comment "Cargo transported in ISO containers" .

maritime:Sensor a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity ;
    rdfs:label "Sensor" ;
    rdfs:comment "Any device producing observational data" .

maritime:AISTransceiver a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Sensor ;
    rdfs:label "AISTransceiver" ;
    rdfs:comment "Automatic Identification System transponder" .

maritime:Radar a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Sensor ;
    rdfs:label "Radar" ;
    rdfs:comment "Radar sensor for vessel/object detection" .

maritime:CCTVCamera a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Sensor ;
    rdfs:label "CCTVCamera" ;
    rdfs:comment "Closed-circuit television camera" .

maritime:WeatherStation a owl:Class ;
    rdfs:subClassOf maritime:PhysicalEntity , maritime:Sensor ;
    rdfs:label "WeatherStation" ;
    rdfs:comment "Meteorological observation station" .

# ---------------------------------------------------------------------------
# 4.2 SpatialEntity 그룹 (5개)
# ---------------------------------------------------------------------------

maritime:SeaArea a owl:Class ;
    rdfs:subClassOf maritime:SpatialEntity ;
    rdfs:label "SeaArea" ;
    rdfs:comment "Named or regulated sea region" .

maritime:EEZ a owl:Class ;
    rdfs:subClassOf maritime:SpatialEntity , maritime:SeaArea ;
    rdfs:label "EEZ" ;
    rdfs:comment "Exclusive Economic Zone (200 NM from baseline)" .

maritime:TerritorialSea a owl:Class ;
    rdfs:subClassOf maritime:SpatialEntity , maritime:SeaArea ;
    rdfs:label "TerritorialSea" ;
    rdfs:comment "Territorial sea (12 NM from baseline)" .

maritime:CoastalRegion a owl:Class ;
    rdfs:subClassOf maritime:SpatialEntity ;
    rdfs:label "CoastalRegion" ;
    rdfs:comment "Coastal administrative or geographic region" .

maritime:GeoPoint a owl:Class ;
    rdfs:subClassOf maritime:SpatialEntity ;
    rdfs:label "GeoPoint" ;
    rdfs:comment "A single geographic coordinate (lat/lon)" .

# ---------------------------------------------------------------------------
# 4.3 TemporalEntity 그룹 (16개)
# ---------------------------------------------------------------------------

maritime:Voyage a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "Voyage" ;
    rdfs:comment "A complete journey of a vessel from origin to destination" .

maritime:PortCall a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "PortCall" ;
    rdfs:comment "A vessel's visit to a specific port" .

maritime:TrackSegment a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "TrackSegment" ;
    rdfs:comment "Contiguous segment of a vessel's AIS track" .

maritime:Incident a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "Incident" ;
    rdfs:comment "Any maritime incident or event" .

maritime:Collision a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Incident ;
    rdfs:label "Collision" ;
    rdfs:comment "Incident involving collision between vessels or objects" .

maritime:Grounding a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Incident ;
    rdfs:label "Grounding" ;
    rdfs:comment "Incident where a vessel runs aground" .

maritime:Pollution a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Incident ;
    rdfs:label "Pollution" ;
    rdfs:comment "Incident involving marine pollution (oil spill, etc.)" .

maritime:Distress a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Incident ;
    rdfs:label "Distress" ;
    rdfs:comment "Emergency situation requiring SAR response" .

maritime:IllegalFishing a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Incident ;
    rdfs:label "IllegalFishing" ;
    rdfs:comment "Detected illegal, unreported, or unregulated (IUU) fishing" .

maritime:WeatherCondition a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "WeatherCondition" ;
    rdfs:comment "Observed or forecasted weather state for an area" .

maritime:Activity a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity ;
    rdfs:label "Activity" ;
    rdfs:comment "A discrete operational activity performed by a vessel" .

maritime:Loading a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Activity ;
    rdfs:label "Loading" ;
    rdfs:comment "Cargo loading activity at port" .

maritime:Unloading a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Activity ;
    rdfs:label "Unloading" ;
    rdfs:comment "Cargo unloading activity at port" .

maritime:Bunkering a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Activity ;
    rdfs:label "Bunkering" ;
    rdfs:comment "Fuel bunkering activity" .

maritime:Anchoring a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Activity ;
    rdfs:label "Anchoring" ;
    rdfs:comment "Activity of anchoring at an anchorage" .

maritime:Loitering a owl:Class ;
    rdfs:subClassOf maritime:TemporalEntity , maritime:Activity ;
    rdfs:label "Loitering" ;
    rdfs:comment "Abnormal loitering behaviour detected from AIS" .

# ---------------------------------------------------------------------------
# 4.4 InformationEntity 그룹 (19개)
# ---------------------------------------------------------------------------

maritime:Regulation a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity ;
    rdfs:label "Regulation" ;
    rdfs:comment "Maritime regulation, convention, or rule" .

maritime:COLREG a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Regulation ;
    rdfs:label "COLREG" ;
    rdfs:comment "Convention on the International Regulations for Preventing Collisions at Sea" .

maritime:SOLAS a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Regulation ;
    rdfs:label "SOLAS" ;
    rdfs:comment "International Convention for the Safety of Life at Sea" .

maritime:MARPOL a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Regulation ;
    rdfs:label "MARPOL" ;
    rdfs:comment "International Convention for the Prevention of Pollution from Ships" .

maritime:IMDGCode a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Regulation ;
    rdfs:label "IMDGCode" ;
    rdfs:comment "International Maritime Dangerous Goods Code" .

maritime:Document a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity ;
    rdfs:label "Document" ;
    rdfs:comment "Any document (report, paper, notice, manifest)" .

maritime:AccidentReport a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Document ;
    rdfs:label "AccidentReport" ;
    rdfs:comment "Official maritime accident/incident report" .

maritime:InspectionReport a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Document ;
    rdfs:label "InspectionReport" ;
    rdfs:comment "Port state control or flag state inspection report" .

maritime:NavigationalWarning a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Document ;
    rdfs:label "NavigationalWarning" ;
    rdfs:comment "Safety navigation warning (NAVTEX, EGC)" .

maritime:CargoManifest a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Document ;
    rdfs:label "CargoManifest" ;
    rdfs:comment "Cargo manifest or bill of lading" .

maritime:DataSource a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity ;
    rdfs:label "DataSource" ;
    rdfs:comment "External data provider or feed" .

maritime:APIEndpoint a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:DataSource ;
    rdfs:label "APIEndpoint" ;
    rdfs:comment "REST/gRPC API endpoint for data ingestion" .

maritime:StreamSource a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:DataSource ;
    rdfs:label "StreamSource" ;
    rdfs:comment "Real-time streaming data source (Kafka, MQTT, etc.)" .

maritime:FileSource a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:DataSource ;
    rdfs:label "FileSource" ;
    rdfs:comment "Batch file-based data source" .

maritime:Service a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity ;
    rdfs:label "Service" ;
    rdfs:comment "Platform micro-service or analytical service" .

maritime:QueryService a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Service ;
    rdfs:label "QueryService" ;
    rdfs:comment "Service handling natural-language to Cypher queries" .

maritime:AnalysisService a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Service ;
    rdfs:label "AnalysisService" ;
    rdfs:comment "Service performing analytical computations" .

maritime:AlertService a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Service ;
    rdfs:label "AlertService" ;
    rdfs:comment "Service generating alerts and notifications" .

maritime:PredictionService a owl:Class ;
    rdfs:subClassOf maritime:InformationEntity , maritime:Service ;
    rdfs:label "PredictionService" ;
    rdfs:comment "Service producing predictive outputs (ETA, risk)" .

# ---------------------------------------------------------------------------
# 4.5 ObservationEntity 그룹 (7개)
# ---------------------------------------------------------------------------

maritime:Observation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity ;
    rdfs:label "Observation" ;
    rdfs:comment "Base type for all observation data" .

maritime:SARObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "SARObservation" ;
    rdfs:comment "Synthetic Aperture Radar satellite observation" .

maritime:OpticalObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "OpticalObservation" ;
    rdfs:comment "Optical satellite observation" .

maritime:CCTVObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "CCTVObservation" ;
    rdfs:comment "Observation derived from CCTV footage" .

maritime:AISObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "AISObservation" ;
    rdfs:comment "Single AIS position report" .

maritime:RadarObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "RadarObservation" ;
    rdfs:comment "Observation derived from radar returns" .

maritime:WeatherObservation a owl:Class ;
    rdfs:subClassOf maritime:ObservationEntity , maritime:Observation ;
    rdfs:label "WeatherObservation" ;
    rdfs:comment "Single meteorological observation record" .

