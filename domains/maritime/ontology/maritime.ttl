# ===========================================================================
# 6. 데이터타입 속성 (Datatype Properties)
# ===========================================================================

# ---------------------------------------------------------------------------
# 6.1 Vessel 속성
# ---------------------------------------------------------------------------

maritime:mmsi a owl:DatatypeProperty ;
    rdfs:domain maritime:Vessel ;
