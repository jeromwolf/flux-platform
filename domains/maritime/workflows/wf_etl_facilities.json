{
  "name": "ETL: KRISO 시험시설 정보 수집",
  "description": "KRISO 8종 시험시설 정보를 크롤링하여 Knowledge Graph에 적재합니다. 매월 1일 새벽 3시에 전체 갱신합니다.",
  "schedule": "0 3 1 * *",
  "trigger": {
    "type": "SCHEDULE",
    "settings": {
      "cronExpression": "0 3 1 * *",
      "timezone": "Asia/Seoul"
    }
  },
  "steps": [
    {
      "name": "trigger_etl",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${API_BASE_URL}/api/v1/etl/trigger",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "${API_KEY}"
        },
        "body": {
          "pipeline_name": "facilities",
          "mode": "full",
          "options": {
            "facilities": [
              "ocean_engineering_basin",
              "towing_tank",
              "ice_tank",
              "deep_ocean_basin",
              "wave_energy_site",
              "hyperbaric_chamber",
              "cavitation_tunnel",
              "ship_simulator"
            ]
          }
        }
      }
    },
    {
      "name": "check_result",
      "type": "CONDITION",
      "settings": {
        "condition": "{{steps.trigger_etl.status}} == 200"
      }
    },
    {
      "name": "notify_success",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "✅ ETL 완료: KRISO 시험시설 정보 수집\n- 처리: {{steps.trigger_etl.body.processed}} 건\n- 실패: {{steps.trigger_etl.body.failed}} 건\n- 소요시간: {{steps.trigger_etl.body.elapsed_seconds}}초"
        }
      },
      "condition": "{{steps.check_result.result}} == true"
    },
    {
      "name": "notify_failure",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "❌ ETL 실패: KRISO 시험시설 정보 수집\n- 오류: {{steps.trigger_etl.body.error}}"
        }
      },
      "condition": "{{steps.check_result.result}} == false"
    }
  ]
}
