{
  "name": "ETL: 시험 데이터 적재",
  "description": "KRISO 시험시설에서 생성된 실험 데이터를 Knowledge Graph에 적재합니다. 웹훅으로 호출하거나 수동 실행합니다.",
  "trigger": {
    "type": "WEBHOOK",
    "settings": {
      "method": "POST",
      "path": "/webhooks/etl/facility-data"
    }
  },
  "steps": [
    {
      "name": "trigger_etl",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${API_BASE_URL}/api/v1/etl/trigger",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "${API_KEY}"
        },
        "body": {
          "pipeline_name": "facility_data",
          "mode": "incremental",
          "options": {
            "facility_id": "{{trigger.body.facility_id}}",
            "data_path": "{{trigger.body.data_path}}",
            "experiment_id": "{{trigger.body.experiment_id}}",
            "metadata": "{{trigger.body.metadata}}"
          }
        }
      }
    },
    {
      "name": "check_result",
      "type": "CONDITION",
      "settings": {
        "condition": "{{steps.trigger_etl.status}} == 200"
      }
    },
    {
      "name": "notify_success",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "✅ ETL 완료: 시험 데이터 적재\n- 시설: {{trigger.body.facility_id}}\n- 실험: {{trigger.body.experiment_id}}\n- 처리: {{steps.trigger_etl.body.processed}} 건\n- 실패: {{steps.trigger_etl.body.failed}} 건\n- 소요시간: {{steps.trigger_etl.body.elapsed_seconds}}초"
        }
      },
      "condition": "{{steps.check_result.result}} == true"
    },
    {
      "name": "notify_failure",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "❌ ETL 실패: 시험 데이터 적재\n- 시설: {{trigger.body.facility_id}}\n- 실험: {{trigger.body.experiment_id}}\n- 오류: {{steps.trigger_etl.body.error}}"
        }
      },
      "condition": "{{steps.check_result.result}} == false"
    }
  ]
}
