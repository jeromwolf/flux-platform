{
  "name": "ETL: 관계 추출 배치",
  "description": "수집된 엔티티 간 관계를 추출하여 Knowledge Graph에 적재합니다. 매주 월요일 새벽 5시에 증분 처리합니다.",
  "schedule": "0 5 * * 1",
  "trigger": {
    "type": "SCHEDULE",
    "settings": {
      "cronExpression": "0 5 * * 1",
      "timezone": "Asia/Seoul"
    }
  },
  "steps": [
    {
      "name": "trigger_etl",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${API_BASE_URL}/api/v1/etl/trigger",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "${API_KEY}"
        },
        "body": {
          "pipeline_name": "relations",
          "mode": "incremental",
          "options": {
            "lookback_days": 7,
            "relation_types": [
              "AUTHORED_BY",
              "PUBLISHED_IN",
              "RELATED_TO",
              "TESTED_AT",
              "LOCATED_IN"
            ],
            "use_llm": false
          }
        }
      }
    },
    {
      "name": "check_result",
      "type": "CONDITION",
      "settings": {
        "condition": "{{steps.trigger_etl.status}} == 200"
      }
    },
    {
      "name": "notify_success",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "✅ ETL 완료: 관계 추출 배치\n- 처리: {{steps.trigger_etl.body.processed}} 건\n- 실패: {{steps.trigger_etl.body.failed}} 건\n- 소요시간: {{steps.trigger_etl.body.elapsed_seconds}}초"
        }
      },
      "condition": "{{steps.check_result.result}} == true"
    },
    {
      "name": "notify_failure",
      "type": "HTTP_REQUEST",
      "settings": {
        "method": "POST",
        "url": "${SLACK_WEBHOOK_URL}",
        "body": {
          "text": "❌ ETL 실패: 관계 추출 배치\n- 오류: {{steps.trigger_etl.body.error}}"
        }
      },
      "condition": "{{steps.check_result.result}} == false"
    }
  ]
}
